---
import BasePageLayout from "@basePageLayout";

const moments = [
  {
    id: 1,
    name: "小明",
    avatar: "https://via.placeholder.com/40",
    content: "今天天气真好，出去散步啦～☀️",
    time: "2小时前",
    likes: 24,
    comments: 3
  },
  {
    id: 2,
    name: "阿花",
    avatar: "https://via.placeholder.com/40",
    content: "刚做完一个超酷的 Astro 项目！🚀",
    time: "5小时前",
    likes: 89,
    comments: 12
  },
  {
    id: 3,
    name: "Qwen",
    avatar: "https://via.placeholder.com/40",
    content: "写代码的时候别忘了喝水💧",
    time: "昨天",
    likes: 102,
    comments: 7
  }
];
---
<BasePageLayout>

</BasePageLayout>

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>我的朋友圈</title>
    <style>
      body {
        background-color: #f0f2f5;
        margin: 0;
        padding: 0;
        color: #333;
      }
      .header {
        background: white;
        padding: 16px 20px;
        border-bottom: 1px solid #e5e5e5;
        text-align: center;
        font-weight: bold;
        font-size: 18px;
      }
      .moments-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 12px;
      }
      .moment {
        background: white;
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
      }
      .moment-header {
        display: flex;
        align-items: center;
        margin-bottom: 12px;
      }
      .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        margin-right: 12px;
      }
      .name {
        font-weight: bold;
        font-size: 16px;
      }
      .time {
        color: #999;
        font-size: 14px;
        margin-left: auto;
      }
      .content {
        line-height: 1.5;
        margin-bottom: 12px;
        white-space: pre-wrap;
      }
      .actions {
        display: flex;
        color: #999;
        font-size: 14px;
      }
      .action {
        margin-right: 20px;
        cursor: pointer;
      }
    </style>
  </head>
  <body>
    <div class="header">朋友圈</div>
    <div class="moments-container">
      {moments.map(moment => (
        <div class="moment" key={moment.id}>
          <div class="moment-header">
            <img src={moment.avatar} alt={moment.name} class="avatar" />
            <span class="name">{moment.name}</span>
            <span class="time">{moment.time}</span>
          </div>
          <div class="content">{moment.content}</div>
          <div class="actions">
            <span class="action">👍 {moment.likes}</span>
            <span class="action">💬 {moment.comments}</span>
          </div>
        </div>
      ))}
    </div>
  </body>
</html>
