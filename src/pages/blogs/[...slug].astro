---
// 获取当前请求的文章
import { getCollection } from "astro:content";
import BasePageLayout from "@basePageLayout";
import "../../style/post-content.css";

// 在 getStaticPaths 中获取所有文章
export async function getStaticPaths() {
  const allPosts = await getCollection("blogs");
  return allPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

// 获取当前 slug 对应的文章
const { slug } = Astro.params;
const allPosts = await getCollection("blogs"); // 重复一次，用于渲染
const post = allPosts.find((p) => p.slug === slug);

// 如果找不到或草稿，重定向
if (!post || post.data.draft) {
  return Astro.redirect("/404");
}

// 渲染 Markdown 内容
const { Content } = await post.render();

// import "../../third-party/github-markdown-css/github-markdown-dark-dimmed.css"
---

<BasePageLayout>
  <article class="post-content">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <div class="post-date">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="18" height="18" rx="2" ry="2"></rect><line
              x1="16"
              y1="2"
              x2="16"
              y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
              x1="3"
              y1="10"
              x2="21"
              y2="10"></line></svg
          >
          {post.data.pubDate.toLocaleDateString("zh-CN")}
        </div>
      </div>
    </header>

    <div class="markdown-body markdown-main-style ">
      <Content class="prose" />
    </div>
  </article>
</BasePageLayout>

<style scoped>
  .post-content {
    max-width: 896px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--gray-300);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.3;
    background: linear-gradient(135deg, var(--cp-500) 0%, var(--cp-400) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-meta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    color: var(--gray-600);
    font-size: 0.95rem;
  }

  .post-date {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: var(--gray-100);
    border-radius: 8px;
    border: 1px solid var(--gray-300);
    transition: all 0.3s;
  }

  .post-date:hover {
    background-color: var(--cp-50);
    border-color: var(--cp-400);
    transform: translateY(-2px);
  }

  .markdown-body {
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
