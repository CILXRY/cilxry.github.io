---
// 获取当前请求的文章
import { getCollection } from "astro:content";
import BasePageLayout from "@basePageLayout";
import "@/styles/standardBlogPage.scss";

// 在 getStaticPaths 中获取所有文章
export async function getStaticPaths() {
  const allPosts = await getCollection("blogs");
  return allPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

// 获取当前 slug 对应的文章
const { slug } = Astro.params;
const allPosts = await getCollection("blogs"); // 重复一次，用于渲染
const post = allPosts.find((p) => p.slug === slug);

// 如果找不到或草稿，重定向
if (!post || post.data.draft) {
  return Astro.redirect("/404");
}

// 渲染 Markdown 内容
const { Content } = await post.render();

import Calendar from "@lucide/astro/icons/calendar-days";

// 声明 ViewImage 的全局类型
declare global {
  interface Window {
    ViewImage?: {
      init: (selector: string) => void;
    };
  }
}
---

<BasePageLayout>
  <article
    py4
    px8
    l-bg-secondary
    rounded-2xl
    dark:d-bg-secondary
    dark:d-text-primary
  >
    <header class="post-header">
      <h1
        class="post-title"
        font800
        text-4xl
        mb-6
        bg-clip-text
        l-text-muted
        dark:d-text-muted
      >
        {post.data.title}
      </h1>
      <div class="post-meta" p0 m0>
        <div class="post-date" px1 py2 m0 flex items-center gap-2>
          <Calendar size="16" />
          {post.data.pubDate.toLocaleDateString("zh-CN")}
        </div>
      </div>
    </header>

    <div class="markdown-main-style max-w-full" view-image>
      <Content />
    </div>
  </article>
  <script src="/scripts/view-image.min.js" is:inline></script>
  <script >
    window.ViewImage && ViewImage.init("img");
  </script>
</BasePageLayout>

<style scoped>

  .post-meta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    color: var(--gray-600);
    font-size: 0.95rem;
  }

  .post-date {
    background-color: var(--gray-100);
    border-radius: 8px;
    border: 1px solid var(--gray-300);
    transition: all 0.3s;
  }

  .post-date:hover {
    background-color: var(--cp-50);
    border-color: var(--cp-400);
    transform: translateY(-2px);
  }

  .markdown-body {
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
