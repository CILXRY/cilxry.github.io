---
// 首页 Dashboard 布局 - 使用 macOS 卡片样式
import BasePageLayout from "@basePageLayout";
import FrameCard from "@cp/StyledCards/FrameCard.astro";
import { DEFAULT_PAGE, HOMEPAGE_CONFIG } from "@/config/c-config.ts";

// Vue Components
import Typer from "../components/Typer/type.vue";

// 获取博客数据（如果配置显示博客卡片）
import { sortedPosts } from "@ut/content/postsMap.ts";

let recentPosts: typeof sortedPosts = [];
if (HOMEPAGE_CONFIG.showBlogCards && DEFAULT_PAGE === "blog") {
  recentPosts = sortedPosts.slice(0, 3);
}

// content += `<p class="text-sm text-gray-600 dark:text-gray-400 mb-3">${creationDate}</p>`;
// if (description) {
//   content += `<p class="text-sm text-gray-500 dark:text-gray-500 line-clamp-2">${description}</p>`;
// }
---

<BasePageLayout k="">
  <Typer client:load />

  {
    HOMEPAGE_CONFIG.showBlogCards && recentPosts.length > 0 && (
      <div class="mt-12 mb-6">
        <h2 class="text-2xl font-bold mb-6 dark:text-gray-100">
          最新文章
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-6">
        {recentPosts.map((post, _index) => (
          <FrameCard contentData={{header: post.data.title,content: `${post.data.creation}<br>${post.data.description}`}} styling={{theme: "macos", floatUp: false}} clickData={{href:`/blogs/${post.slug}`}}/>
        ))}
      </div>
    )
  }


  {
    HOMEPAGE_CONFIG.showStatsCard && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6 mb-6">
        <FrameCard styling={{theme: "macos", floatUp: false}}>
          <div class="p-4">
            <h3 class="text-lg font-semibold mb-3 dark:text-gray-100">
              统计信息
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              这里可以显示文章数量、访问统计等
            </p>
          </div>
        </FrameCard>
      </div>
    )
  }
</BasePageLayout>
