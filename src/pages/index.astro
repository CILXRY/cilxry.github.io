---
// 首页 Dashboard
import BasePageLayout from "@basePageLayout";
const name = "CILXRY";
import { sortedPosts } from "@ut/content/postsMap.ts";

let recentPosts: typeof sortedPosts = [];
recentPosts = sortedPosts.slice(0, 4);

import FrameCard from "@cp/StyledCards/FrameCard.astro";
---

<BasePageLayout k="">
  <div md:flex sm:px-4>
    <div flex md:block md:h-xl w-xl text-colord>
      <img src="https://avatar.cilxry.cc" alt="" rounded-full h-32 w-32 />
      <header ml-6 my-a md:ml0 mt6>
        <h1 text-5xl font-400 m-0>{name}</h1>
        <h3 font-400 mb-0>许愿 如所愿 皆所愿</h3>
      </header>
    </div>
    <div text-colord flex-auto mt6 md:mt0>
      <h1 mt0>Last Writing</h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        {
          recentPosts.map((post, _index) => (
            <FrameCard
              contentData={{
                header: post.data.title,
                content: `${post.data.creation}<br>${post.data.description}`,
              }}
              styling={{ theme: "macos", floatUp: false }}
              clickData={{ href: `/posts/${post.id}` }}
            />
          ))
        }
      </div>
    </div>
  </div>

  <!-- {
    HOMEPAGE_CONFIG.showStatsCard && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-6 mb-6">
        <FrameCard styling={{ theme: "macos", floatUp: false }}>
          <div class="p-4">
            <h3 class="text-lg font-semibold mb-3 dark:text-gray-100">统计信息</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              这里可以显示文章数量、访问统计等
            </p>
          </div>
        </FrameCard>
      </div>
    )
  } -->
</BasePageLayout>
