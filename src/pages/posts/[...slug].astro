---
// 基础骨架和样式表
import BasePageLayout from "@basePageLayout";
import "@/styles/standardBlogPage.scss";

// 渲染和获取内容
import { render } from "astro:content";
import { safeGetCollection } from "@ut/content/safeCollection.ts";

export async function getStaticPaths() {
  const allPosts = await safeGetCollection("posts");
  return allPosts.map((post) => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const allPosts = await safeGetCollection("posts");
const post = allPosts.find((p) => p.id === slug);

if (!post || post.data.draft) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(post);

const firstH1 = headings.find((h) => h.depth === 1);
const displayTitle = firstH1?.text ?? post.data.title;

import Calendar from "@lucide/astro/icons/calendar-days";
import Modified from "@lucide/astro/icons/pencil";

import Category from "@lucide/astro/icons/chart-column-stacked";
import Tags from "@lucide/astro/icons/tags";

// 声明 ViewImage 的全局类型
declare global {
  interface Window {
    ViewImage?: {
      init: (selector: string) => void;
    };
  }
}
---

<BasePageLayout k={post.data.title} styled={"default"}>
  <article
    py4
    px8
    l-bg-secondary
    rounded-2xl
    dark:d-bg-secondary
    dark:d-text-primary
  >
    <header class="post-header">
      <h1
        class="post-title"
        font800
        text-4xl
        mb-6
        bg-clip-text
        l-text-muted
        dark:d-text-muted
      >
        {displayTitle}
      </h1>
      <div class="post-meta" flex p0 m0>
        <div class="post-date" px1 py2 m0 flex items-center gap-2>
          <Calendar size="16" />
          {
            post.data.creation
              ? post.data.creation.toLocaleDateString("zh-CN")
              : "缺失创建时间"
          }
        </div>
        <div class="post-date" px1 py2 m0 flex items-center gap-2>
          <Modified size="16" />
          {
            post.data.published
              ? post.data.published.toLocaleDateString("zh-CN")
              : "缺失修改时间"
          }
        </div>
        <div class="post-date" px1 py2 m0 flex items-center gap-2>
          <Category size="16" />
          {post.data.category ? post.data.category : "没有分类"}
        </div>
        <div class="post-date" px1 py2 m0 flex items-center gap-2>
          <Tags size="16" />
          {post.data.tags ? post.data.tags : "没有标签"}
        </div>
      </div>
    </header>

    <div
      class:list={[
        "markdown-main-style",
        "max-w-full",
        { "has-content-h1": firstH1 },
      ]}

    >
      <Content view-image/>

      <div id="tcomment"></div>
      <script src="/scripts/twikoo.min.js" is:inline></script>
      <script>
        window.addEventListener("load", () => {
          (window as any).twikoo.init({
            envId: "http://8.159.156.167:29204/",
            el: "#tcomment",
          });
        });
      </script>
    </div>
  </article>
  <script src="/scripts/view-image.min.js" is:inline></script>
  <script>
    window.ViewImage && window.ViewImage.init("img");
  </script>
</BasePageLayout>

<style scoped>
  .post-meta {
    gap: 1.5rem;
    align-items: center;
    color: var(--gray-600);
    font-size: 0.95rem;
  }

  .post-date {
    background-color: var(--gray-100);
    border-radius: 8px;
    border: 1px solid var(--gray-300);
    transition: all 0.3s;
  }

  .post-date:hover {
    background-color: var(--cp-50);
    border-color: var(--cp-400);
    transform: translateY(-2px);
  }

  .markdown-body {
    animation: fadeInUp 0.6s ease-out;
  }

  .has-content-h1 :global(h1:first-of-type) {
    display: none;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
