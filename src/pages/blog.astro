---
import BasePageLayout from "@basePageLayout";
import EchoCard from "../components/StyledCards/blog_post_card.astro";
import { assignGradients } from "../utils/ExampleUtils/echoCardColorUtils.ts";

// 1. 获取所有已发布（非草稿）的博客
import { sortedPosts,categories,tags } from "@ut/content/postsMap.ts";

// 2. 按发布时间倒序排列（最新在前）

const gradients = assignGradients(sortedPosts.length);

// 4. 分页相关配置
const postsPerPage = 10; // 每页显示的博客数量
const totalPosts = sortedPosts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
import SearchBox from "@cp/SearchBox.svelte";

---

<BasePageLayout k="blog">
  <!-- 搜索和过滤控制栏 -->
  <div
    class="mb-8 p-6 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700"
  >
    <!-- 搜索框 -->
    <div class="mb-4">
      <SearchBox />
    </div>

    <!-- 分类和标签过滤器 -->
    <div class="flex flex-wrap gap-4">
      <!-- 分类选择 -->
      <div class="flex-1 min-w-[200px]">
        <label
          class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
        >
          📁 分类
        </label>
        <select
          id="category-filter"
          class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all cursor-pointer"
        >
          <option value="">全部分类</option>
          {
            categories.map((category) => (
              <option value={category!}>{category}</option>
            ))
          }
        </select>
      </div>

      <!-- 标签选择 -->
      <div class="flex-1 min-w-[200px]">
        <label
          class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
        >
          🏷️ 标签
        </label>
        <select
          id="tag-filter"
          class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all cursor-pointer"
        >
          <option value="">全部标签</option>
          {tags.map((tag) => <option value={tag}>{tag}</option>)}
        </select>
      </div>
    </div>

    <!-- 激活的过滤器显示 -->
    <div id="active-filters" class="mt-4 flex flex-wrap gap-2 hidden">
      <!-- 动态插入激活的过滤器标签 -->
    </div>

    <!-- 结果计数 -->
    <div class="mt-4 text-sm text-gray-500 dark:text-gray-400">
      显示 <span id="result-count">{sortedPosts.length}</span> / {sortedPosts.length} 篇文章
    </div>
  </div>

  <!-- 博客卡片列表 -->
  <div id="blog-list">
    {
      sortedPosts.map((post, index) => {
        // 将 Date 转换为字符串以匹配 EchoCard 的类型定义
        const cardData = {
          title: post.data.title,
          description: post.data.description,
          published: post.data.creation.toISOString(),
          tags: post.data.tags || [],
          categories: post.data.category || undefined,
          wordCount: post.data.wordCount ?? undefined,
          readingTime: post.data.readingTime ?? undefined,
        };
        return (
          <EchoCard
            postData={cardData}
            gradient={gradients[index]}
            link={`/posts/${post.id}/`}
            data-category={post.data.category || ""}
            data-tags={(post.data.tags || []).join(",")}
          />
        );
      })
    }
  </div>

  <!-- 分页导航 -->
  <div class="mt-8 flex flex-col items-center">
    <div id="page-info" class="mb-4 text-sm text-gray-500 dark:text-gray-400"></div>
    <div id="pagination" class="flex items-center gap-2"></div>
  </div>
</BasePageLayout>

<script>
  // 博客搜索和过滤功能
  const searchInput = document.getElementById("blog-search") as HTMLInputElement;
  const categoryFilter = document.getElementById(
    "category-filter"
  ) as HTMLSelectElement;
  const tagFilter = document.getElementById("tag-filter") as HTMLSelectElement;
  const activeFiltersContainer = document.getElementById("active-filters");
  const resultCount = document.getElementById("result-count");
  const blogList = document.getElementById("blog-list");
  const paginationContainer = document.getElementById("pagination");
  const pageInfo = document.getElementById("page-info");

  let currentCategory = "";
  let currentTag = "";
  let currentSearchQuery = "";
  let currentPage = 1;
  const postsPerPage = 10;

  // 过滤博客文章
  function filterBlogs() {
    const cards = blogList?.querySelectorAll("[data-category]");
    let visibleCount = 0;

    cards?.forEach((card) => {
      const category = card.getAttribute("data-category") || "";
      const tags = card.getAttribute("data-tags") || "";
      const title = card.querySelector("h3")?.textContent?.toLowerCase() || "";
      const description = card.querySelector("p")?.textContent?.toLowerCase() || "";

      // 检查是否匹配所有条件
      const matchesCategory = !currentCategory || category === currentCategory;
      const matchesTag = !currentTag || tags.includes(currentTag);
      const matchesSearch =
        !currentSearchQuery ||
        title.includes(currentSearchQuery.toLowerCase()) ||
        description.includes(currentSearchQuery.toLowerCase());

      if (matchesCategory && matchesTag && matchesSearch) {
        card.classList.remove("hidden");
        visibleCount++;
      } else {
        card.classList.add("hidden");
      }
    });

    // 更新结果计数
    if (resultCount) {
      resultCount.textContent = visibleCount.toString();
    }

    // 更新活动过滤器显示
    updateActiveFilters();

    // 重置到第一页并更新分页
    currentPage = 1;
    updatePagination();
  }

  // 更新活动过滤器标签
  function updateActiveFilters() {
    if (!activeFiltersContainer) return;

    const filters = [];
    if (currentCategory) {
      filters.push({ type: "category", value: currentCategory });
    }
    if (currentTag) {
      filters.push({ type: "tag", value: currentTag });
    }

    if (filters.length === 0) {
      activeFiltersContainer.classList.add("hidden");
    } else {
      activeFiltersContainer.classList.remove("hidden");
      activeFiltersContainer.innerHTML = filters
        .map(
          (filter) => `
          <span class="inline-flex items-center gap-1 px-3 py-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded-full text-sm">
            ${filter.type === "category" ? "📁" : "🏷️"} ${filter.value}
            <button
              onclick="removeFilter('${filter.type}')"
              class="ml-1 hover:text-blue-900 dark:hover:text-blue-100 transition-colors"
              aria-label="移除过滤器"
            >
              ✕
            </button>
          </span>
        `
        )
        .join("");
    }
  }

  // 移除过滤器
  (window as any).removeFilter = function (type: string) {
    if (type === "category") {
      currentCategory = "";
      if (categoryFilter) categoryFilter.value = "";
    } else if (type === "tag") {
      currentTag = "";
      if (tagFilter) tagFilter.value = "";
    }
    filterBlogs();
  };

  // 分页相关函数
  function updatePagination() {
    const visibleCards =
      blogList?.querySelectorAll("[data-category]:not(.hidden)") || [];
    const totalVisible = visibleCards.length;
    const totalPages = Math.ceil(totalVisible / postsPerPage);

    // 更新分页信息
    if (pageInfo) {
      pageInfo.textContent = `第 ${currentPage} 页，共 ${totalPages} 页`;
    }

    // 生成分页按钮
    if (paginationContainer) {
      let paginationHTML = "";

      // 上一页按钮
      paginationHTML += `<button
        onclick="changePage(${currentPage - 1})"
        class="px-3 py-1 rounded-md border ${currentPage === 1 ? "bg-gray-100 text-gray-400 cursor-not-allowed" : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"}"
        ${currentPage === 1 ? "disabled" : ""}
      >上一页</button>`;

      // 页码按钮
      for (let i = 1; i <= totalPages; i++) {
        paginationHTML += `<button
          onclick="changePage(${i})"
          class="px-3 py-1 mx-1 rounded-md border ${currentPage === i ? "bg-blue-500 text-white" : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"}"
        >${i}</button>`;
      }

      // 下一页按钮
      paginationHTML += `<button
        onclick="changePage(${currentPage + 1})"
        class="px-3 py-1 rounded-md border ${currentPage === totalPages ? "bg-gray-100 text-gray-400 cursor-not-allowed" : "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"}"
        ${currentPage === totalPages ? "disabled" : ""}
      >下一页</button>`;

      paginationContainer.innerHTML = paginationHTML;
    }

    // 显示当前页的卡片
    showCurrentPageCards();
  }

  function changePage(page: number) {
    const visibleCards =
      blogList?.querySelectorAll("[data-category]:not(.hidden)") || [];
    const totalPages = Math.ceil(visibleCards.length / postsPerPage);

    if (page >= 1 && page <= totalPages) {
      currentPage = page;
      updatePagination();
    }
  }

  function showCurrentPageCards() {
    const visibleCards =
      blogList?.querySelectorAll("[data-category]:not(.hidden)") || [];
    const startIndex = (currentPage - 1) * postsPerPage;
    const endIndex = startIndex + postsPerPage;

    visibleCards.forEach((card, index) => {
      if (index >= startIndex && index < endIndex) {
        card.classList.remove("page-hidden");
      } else {
        card.classList.add("page-hidden");
      }
    });
  }

  // 事件监听
  searchInput?.addEventListener("input", (e) => {
    currentSearchQuery = (e.target as HTMLInputElement).value.trim();
    filterBlogs();
  });

  categoryFilter?.addEventListener("change", (e) => {
    currentCategory = (e.target as HTMLSelectElement).value;
    filterBlogs();
  });

  tagFilter?.addEventListener("change", (e) => {
    currentTag = (e.target as HTMLSelectElement).value;
    filterBlogs();
  });

  // 初始加载
  window.addEventListener("DOMContentLoaded", () => {
    filterBlogs();
  });
</script>

<style>
  /* 为隐藏的卡片添加过渡动画 */
  #blog-list > [*] {
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  #blog-list > [*].hidden {
    display: none;
  }

  #blog-list > [*].page-hidden {
    display: none;
  }
</style>
