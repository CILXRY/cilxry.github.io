---
import Search from "@lucide/astro/icons/search";

interface SearchResult {
  title: string;
  href: string;
  excerpt?: string;
  date?: string;
}

interface Props {
  placeholder?: string;
  searchData?: SearchResult[];
}

const { placeholder = "搜索文章标题或描述...", searchData } = Astro.props;
---

<div class="relative">
  <input
    type="text"
    id="search-input"
    class="w-full px-4 py-2 pl-10 pr-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cp-500 focus:border-transparent transition-all"
    placeholder={placeholder}
    aria-label="搜索"
  />
  <Search
    class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"
  />

  <!-- 搜索结果下拉 -->
  <div
    id="search-results"
    class="absolute top-full left-0 right-0 mt-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl max-h-96 overflow-y-auto hidden z-50"
  >
    <div id="search-results-content" class="p-2">
      <!-- 搜索结果将动态插入这里 -->
    </div>
  </div>
</div>

<!-- 移动端搜索面板 -->
<div
  id="search-mobile-panel"
  class="fixed inset-0 bg-white dark:bg-gray-900 z-50 hidden"
>
  <div class="p-4 border-b border-gray-200 dark:border-gray-700">
    <div class="flex items-center gap-2">
      <input
        type="text"
        id="search-input-mobile"
        class="flex-1 px-4 py-2 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-900 dark:text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cp-500"
        placeholder={placeholder}
        autofocus
      />
      <button
        id="search-mobile-close"
        class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="p-4 overflow-y-auto" style="height: calc(100vh - 80px)">
    <div id="search-results-mobile" class="space-y-2"></div>
  </div>
</div>

<button
  id="search-toggle-mobile"
  class="lg:hidden p-2 text-gray-600 dark:text-gray-300 hover:text-cp-600 dark:hover:text-cp-400 transition-colors"
  aria-label="搜索"
>
  <Search class="w-5 h-5" />
</button>

{searchData && (
  <script type="application/json" id="search-data-json">
    {JSON.stringify(searchData)}
  </script>
)}

<script>
  const searchInput = document.getElementById("search-input");
  const searchResults = document.getElementById("search-results");
  const searchResultsContent = document.getElementById(
    "search-results-content",
  );
  const searchToggleMobile = document.getElementById("search-toggle-mobile");
  const searchMobilePanel = document.getElementById("search-mobile-panel");
  const searchInputMobile = document.getElementById("search-input-mobile");
  const searchResultsMobile = document.getElementById("search-results-mobile");
  const searchMobileClose = document.getElementById("search-mobile-close");

  let debounceTimer: string | number | NodeJS.Timeout | undefined;
  let searchData: any[] = [];

  function loadSearchData() {
    const embeddedData = document.getElementById("search-data-json");
    if (embeddedData && embeddedData.textContent) {
      try {
        searchData = JSON.parse(embeddedData.textContent);
        return;
      } catch (e) {
        console.error("解析搜索数据失败:", e);
      }
    }

    searchData = [];
  }

  // 搜索功能
  function performSearch(query: string, isMobile: boolean | undefined) {
    if (isMobile === undefined) isMobile = false;
    if (!query.trim()) {
      hideResults(isMobile);
      return;
    }

    const results = searchData
      .filter(
        (item) =>
          item.title.toLowerCase().includes(query.toLowerCase()) ||
          (item.excerpt &&
            item.excerpt.toLowerCase().includes(query.toLowerCase())),
      )
      .slice(0, 10);

    renderResults(results, isMobile);
  }

  // 渲染搜索结果
  function renderResults(results: any[], isMobile: boolean | undefined) {
    if (isMobile === undefined) isMobile = false;
    const container = isMobile ? searchResultsMobile : searchResultsContent;
    if (!container) return;

    if (results.length === 0) {
      container.innerHTML = `
        <div class="p-4 text-center text-gray-500 dark:text-gray-400">
          暂无搜索结果
        </div>
      `;
    } else {
      container.innerHTML = results
        .map(
          (item: { href: any; title: any; excerpt: any; date: any; }) => `
        <a
          href="${item.href}"
          class="block p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
        >
          <h4 class="font-medium text-gray-900 dark:text-gray-100 mb-1">
            ${item.title}
          </h4>
          ${item.excerpt ? `<p class="text-sm text-gray-500 dark:text-gray-400 mb-1 truncate">${item.excerpt}</p>` : ""}
          ${item.date ? `<p class="text-xs text-gray-400 dark:text-gray-500">${item.date}</p>` : ""}
        </a>
      `,
        )
        .join("");
    }

    showResults(isMobile);
  }

  // 显示搜索结果
  function showResults(isMobile: boolean | undefined) {
    if (isMobile === undefined) isMobile = false;
    if (isMobile) {
      searchResultsMobile?.parentElement?.classList.remove("hidden");
    } else {
      searchResults?.classList.remove("hidden");
    }
  }

  // 隐藏搜索结果
  function hideResults(isMobile: boolean | undefined) {
    if (isMobile === undefined) isMobile = false;
    if (isMobile) {
      searchResultsMobile?.parentElement?.classList.add("hidden");
    } else {
      searchResults?.classList.add("hidden");
    }
  }

  // 事件监听
  searchInput?.addEventListener("input", (e) => {
    clearTimeout(debounceTimer);
    const target = e.target;
    const query = target.value;

    debounceTimer = setTimeout(() => {
      performSearch(query, false);
    }, 300);
  });

  searchInputMobile?.addEventListener("input", (e) => {
    clearTimeout(debounceTimer);
    const target = e.target;
    const query = target.value;

    debounceTimer = setTimeout(() => {
      performSearch(query, true);
    }, 300);
  });

  // 点击外部关闭搜索结果
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (
      !target.closest("#search-input") &&
      !target.closest("#search-results")
    ) {
      hideResults(false);
    }
  });

  // 移动端搜索开关
  searchToggleMobile?.addEventListener("click", () => {
    searchMobilePanel?.classList.remove("hidden");
    searchInputMobile?.focus();
  });

  searchMobileClose?.addEventListener("click", () => {
    searchMobilePanel?.classList.add("hidden");
    searchInputMobile!.value = "";
    hideResults(true);
  });

  // ESC 键关闭
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      hideResults(false);
      hideResults(true);
      searchMobilePanel?.classList.add("hidden");
    }
  });

  // 初始化
  loadSearchData();
</script>
