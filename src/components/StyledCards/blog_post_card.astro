---
interface Props {
  postData: {
    type?: string;
    slug?: string;
    title: string;
    excerpt?: string;
    date?: string;
    published?: string;
    tags?: string[];
    categories?: string;
    description: string;
    wordCount?: number;
    readingTime?: number;
    ai_summary?: string;
  };
  gradient?: string;
  link: string;
  "data-category"?: string;
  "data-tags"?: string;
}

const {
  postData,
  gradient = "linear-gradient(315deg, var(--cp-400), var(--cp-600))",
  link,
  "data-category": dataCategory,
  "data-tags": dataTags,
} = Astro.props;

// 格式化日期显示
const formatDate = (dateStr?: string) => {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    });
  } catch {
    return dateStr;
  }
};
---

<a href={link} class="blog-card" data-category={dataCategory} data-tags={dataTags}>
  <div class="card-content">
    <!-- 左侧黄色竖条 -->
    <div class="card-indicator"></div>

    <!-- 卡片主体 -->
    <div class="card-body">
      <!-- 标题 -->
      <h2 class="card-title">
        {postData.type === 'draft' && <span class="draft-badge">Draft</span>}
        {postData.title}
      </h2>

      <!-- 元信息行：日期、分类、标签 -->
      <div class="meta-row">
        {postData.published && (
          <span class="meta-item">
            <span class="meta-icon">📅</span>
            {formatDate(postData.published)}
          </span>
        )}
        {postData.categories && (
          <span class="meta-item">
            <span class="meta-icon">📁</span>
            {postData.categories}
          </span>
        )}
        {postData.tags && postData.tags.length > 0 && (
          <span class="meta-item tags">
            <span class="meta-icon">#</span>
            {postData.tags.join(' / ')}
          </span>
        )}
      </div>

      <!-- 描述内容 -->
      <p class="card-description">{postData.description || postData.excerpt}</p>

      <!-- 底部信息：字数和阅读时间 -->
      <div class="card-footer">
        {postData.wordCount && (
          <span class="footer-item">{postData.wordCount} 字</span>
        )}
        {postData.readingTime && (
          <span class="footer-item">| {postData.readingTime} 分钟</span>
        )}
      </div>
    </div>

    <!-- 右侧箭头 -->
    <div class="card-arrow">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    </div>
  </div>
</a>

<style scoped>
