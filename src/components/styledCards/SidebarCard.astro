---
/**
 * SidebarCard - 通用侧边栏卡片组件
 * 可用于展示公告、简介、统计信息等
 */

interface Props {
  title?: string;
  content?: string;
  icon?: 'user' | 'star' | 'heart' | 'info' | 'notification';
  customIconSvg?: string;
  gradient?: string;
  href?: string;
  clickable?: boolean;
}

const {
  title = '卡片标题',
  content = '卡片内容',
  icon = 'info',
  customIconSvg,
  gradient = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
  href = '#',
  clickable = false,
} = Astro.props;

// 图标映射
const icons = {
  user: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  heart: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`,
  info: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
  notification: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>`,
};

const selectedIcon = customIconSvg || (icon ? icons[icon] : icons.info);
---

<div class={`sidebar-card ${clickable ? 'clickable' : ''}`}>
  <div class="card-header">
    <div class="icon-wrapper" set:html={selectedIcon} />
    <h3 class="card-title">{title}</h3>
  </div>
  {content && <p class="card-content">{content}</p>}
  {clickable && (
    <a href={href} class="card-link">
      <span>了解更多</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </a>
  )}
</div>

<style scoped>
  .sidebar-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .sidebar-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--card-gradient, linear-gradient(135deg, #667eea 0%, #764ba2 100%));
    border-radius: 12px 12px 0 0;
  }

  .sidebar-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .sidebar-card.clickable {
    cursor: pointer;
  }

  .sidebar-card.clickable:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .icon-wrapper {
    width: 32px;
    height: 32px;
    min-width: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    background: var(--card-gradient, linear-gradient(135deg, #667eea 0%, #764ba2 100%));
    border-radius: 8px;
    padding: 6px;
  }

  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
    flex: 1;
  }

  .card-content {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin: 0 0 12px 0;
  }

  .card-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 6px 0;
  }

  .card-link:hover {
    color: #fff;
    gap: 10px;
  }

  .card-link :global(svg) {
    transition: all 0.2s ease;
  }

  /* 亮色模式适配 */
  @media (prefers-color-scheme: light) {
    .sidebar-card {
      background: rgba(255, 255, 255, 0.9);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .sidebar-card:hover {
      background: rgba(255, 255, 255, 0.95);
    }

    .card-title {
      color: #1f2937;
    }

    .card-content {
      color: #4b5563;
    }

    .card-link {
      color: #6b7280;
    }

    .card-link:hover {
      color: #1f2937;
    }
  }
</style>
