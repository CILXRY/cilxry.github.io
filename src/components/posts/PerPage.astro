---
import ShowenCard from "./ShowenCard.astro";

import { sortedPosts } from "@ut/content/postsMap.ts";
---

<div class="columns-1 md:columns-2 lg:columns-3 gap-6">
  {
    sortedPosts.map((post, _index) => (
      <div mb-6 break-inside-avoid>
        <ShowenCard
          header={post.data.title}
          creation={post.data.creation.toDateString()}
          content={post.data.description}
          category={post.data.category}
          tags={post.data.tags?.toString()}
          href={`/posts/${post.id}/`}
        />
      </div>
    ))
  }
</div>
{sortedPosts.length === 0 && <div text-align-center>还没有写文章哦</div>}
