---
interface Props {
  header: string;
  creation: Date;
  content: string;
  category?: string;
  tags: string[];
  wordCount?: number;
  readingTime?: number;
  href: string;
}
import FrameCard from "@cp/StyledCards/FrameCard.astro";

const { header, creation, content, category, tags, wordCount, readingTime, href } = Astro.props;

const formattedDate = creation.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<FrameCard styling={{ theme: "macos", floatUp: true }} clickData={{ href: href }}>
  <div class="flex flex-col gap-3">
    <h2
      class="text-xl font-bold m-0 dark:text-gray-100 transition-colors duration-300"
    >
      {header}
    </h2>
    <div
      class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500 dark:text-gray-400"
    >
      <span>{formattedDate}</span>
      {category && (
        <span
          class="px-2 py-0.5 rounded-full text-xs font-medium bg-[--cp-100] text-[--cp-700] dark:bg-[--cp-900] dark:text-[--cp-300]"
        >
          {category}
        </span>
      )}
      {wordCount != null && <span>{wordCount} 字</span>}
      {readingTime != null && <span>{readingTime} 分钟阅读</span>}
    </div>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span
            class="px-2 py-0.5 rounded-md text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"
          >
            {tag}
          </span>
        ))}
      </div>
    )}
    <p
      class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed line-clamp-3 m-0"
      set:html={content}
    />
  </div>
</FrameCard>
