---
interface Props {
  header: string;
  creation: string;
  content: string;
  category?: string;
  tags: string;
  href: string;
}
import FrameCard from "@cp/StyledCards/FrameCard.astro";

const { header, creation, content, category = "未归类", tags, href } = Astro.props;
---

<FrameCard styling={{ theme: "macos", floatUp: false }} clickData={{ href: href }}>
  <div>
    <h2
      class="text-2xl font-semibold m-0 mb-0 dark:text-gray-100 transition-colors duration-300"
    >
      {header}
    </h2>
    <p text-sm font-bold m-0 mb-2 underline dark:text-gray-200 underline-coolGray>
      {creation} | {category} | {tags}
    </p>
    <p
      class="text-base text-gray-600 dark:text-gray-300 leading-relaxed transition-colors duration-300"
      set:html={content}
    />
  </div>
</FrameCard>
