---
interface Props {
  k: string;
  styled?: "default";
}
import BasePageFrame from "./BasePageLayoutFrames/BasePageFrame.astro";
import { translate } from "@/i18n/index.ts";
const { k, styled = "default" } = Astro.props;

import "@/styles/base.scss";
---

{
  styled === "default" && (
    <BasePageFrame websiteLanguage="zh-CN" websiteTitle={translate(k)}>
      <slot />
    </BasePageFrame>
  )
}
