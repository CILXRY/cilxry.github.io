---
import BasePageFrame from "./BasePageFrame.astro";
interface Props {
  websiteLanguage: "zh-CN" | "en-US";
  websiteTitle: string;
  description?: string;
}
const { websiteLanguage, websiteTitle, description } = Astro.props;
---

<BasePageFrame
  websiteLanguage={websiteLanguage}
  websiteTitle={websiteTitle}
  description={description}
  ><slot />
</BasePageFrame>
