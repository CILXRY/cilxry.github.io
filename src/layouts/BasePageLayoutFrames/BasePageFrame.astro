<style>
  /* ===== SWUP 页面过渡动画 ===== */
  /*
   * SWUP 在页面切换时会添加这些类到 <html> 标签：
   * - is-animating: 整个动画过程中
   * - is-leaving: 页面离开阶段
   * - is-rendering: 新页面渲染阶段
   * - is-mounted: 新页面已挂载
   */

  /* 基础过渡效果 - 淡入淡出 */
  html.is-animating {
    overflow: hidden; /* 防止动画期间滚动 */
  }

  /* 旧页面离开：淡出 */
  html.is-leaving body#swup {
    animation: swup-fade-out 0.4s ease-in-out forwards;
  }

  /* 新页面进入：隐藏直到挂载 */
  html.is-rendering body#swup {
    opacity: 0;
  }

  /* 新页面挂载后：淡入显示 */
  html.is-mounted body#swup {
    animation: swup-fade-in 0.4s ease-in-out forwards;
  }

  @keyframes swup-fade-out {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  @keyframes swup-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }


</style>
