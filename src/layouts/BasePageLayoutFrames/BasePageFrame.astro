---
// 如果温柔是罪。
// Base Color Style
import "@/style/colorProfileStyle.css";

// Props Here
interface Props {
  websiteTitle?: string;
  websiteLanguage?: string;
}
const { websiteTitle = "CILXRY 的小站 ", websiteLanguage = "zh-CN" } =
  Astro.props;

// Astro Components and Layouts Here
import NavBar from "@cp/Navbar.astro";
import Footer from "@cp/Footer/Footer.astro";
import SwupTransition from "@cp/Swup/SwupTransition.vue";
import CodeBlockCopy from "@cp/Blog/CodeBlockCopy.vue";
---

<!doctype html>
<html lang={websiteLanguage}>
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, max-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>{websiteTitle}</title>
    <meta name="description" content="这是 CILXRY 的个人网站" />
    <meta name="author" content="CILXRY" />
    <meta property="og:title" content={websiteTitle} />
    <meta property="og:description" content="这是 CILXRY 的个人网站" />
    <!-- <meta property="og:image" content="https://cilxry.cc/banner.webp"> -->
    <!-- <meta property="og:url" content="https://cilxry.cc"> -->
    <!-- <meta name="theme-color" content="#cccccc" /> -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="shortcut icon" href="favicon.svg" />

    <slot name="InsHeader" />
  </head>
  <body
    id="swup"
    data-swup
    class="l-bg-primary dark:d-bg-primary"
    text="left [var(--light-text-secondary)] dark:[var(--gray-400)]"
    font-sans
    antialiased
    max-w-full
    px="6 md:12"
    py-0
    my-0
    duration-500
  >
    <NavBar />
    <main
      id="swup-transitions"
      data-swup-transition-container
      class="max-w-7xl mx-auto pb-16 md:py-20"
    >
      <slot />
    </main>
    <Footer />

    <!-- SWUP Vue 组件 -->
    <SwupTransition client:only="vue" />
    
    <!-- 代码块复制功能组件 -->
    <CodeBlockCopy client:load />
  </body>
</html>

