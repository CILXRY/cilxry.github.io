---
interface Props {
  title: string;
  description?: string;
}
import { SiteConfig } from "@cfg/c-config.ts";
import { siteTitle } from "@ut/returnSiteTitle.ts";

const { title, description = SiteConfig.defaultDescription } = Astro.props;

// TODO 三方 Link 的 Image 展示
---

<head>
  <!-- 标题莫动 -->
  <title>{siteTitle(title)}</title>

  <!-- 字符集 -->
  <meta charset="UTF-8" />

  <!-- 描述和作者信息 -->
  <meta name="description" content={description} />
  <meta name="author" content={SiteConfig.author} />

  <!-- 视口 禁用缩放 -->
  <!-- 这是一个比较需要思考的选项， maximum-scale 小于 3.0 或者 user-scaleable 为 no 都违反 WCAG -->
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1, minimum-scale=1.0, maximum-scale=1.0, user-scalable=no"
  />

  <!-- 三方 Link 所展示信息 -->

  <meta property="og:title" content={siteTitle(title)} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:site_name" content={siteTitle(title)} />
  <meta property="og:description" content={description} />

  <!-- 其他内容 -->
  <meta name="robots" content="noindex, nofollow" />
  <link rel="shortcut icon" href="favicon.svg" />

  <!-- Swup 过渡动画样式 -->
  <style is:global>
    /* 淡入淡出动画 - transition 必须始终存在 */
    .transition-fade {
      transition: opacity 0.4s ease-in-out;
      opacity: 1;
    }

    /* 页面离开和进入时的动画状态 */
    html.is-animating .transition-fade {
      opacity: 0;
    }

    /* 可选：滑动动画 */
    .transition-slide {
      transition:
        opacity 0.4s ease-in-out,
        transform 0.4s ease-in-out;
      opacity: 1;
      transform: translateY(0);
    }

    html.is-animating .transition-slide {
      opacity: 0;
      transform: translateY(-20px);
    }
  </style>

  <slot name="AttachedHeader" /></head
>
