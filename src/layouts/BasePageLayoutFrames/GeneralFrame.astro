---
// 通用页面布局框架（带公告栏、社交链接等）
import BasePageFrame from "./BasePageFrame.astro";
import AnnouncementBar from "@/layouts/LayoutComponents/AnnouncementBar.astro";
import SocialLinks from "@/layouts/LayoutComponents/SocialLinks.astro";
import BackToTop from "@/layouts/LayoutComponents/BackToTop.astro";

interface Props {
  websiteTitle?: string;
  websiteLanguage?: string;
  announcementMessage?: string;
  announcementType?: "info" | "success" | "warning" | "error";
  showSocialLinks?: boolean;
}

const {
  websiteTitle = "CILXRY 的小站",
  websiteLanguage = "zh-CN",
  announcementMessage,
  announcementType = "info",
  showSocialLinks = false,
} = Astro.props;
---

<BasePageFrame {websiteTitle} {websiteLanguage}>
  <!-- 公告栏（可选） -->
  {
    announcementMessage && (
      <AnnouncementBar
        message={announcementMessage}
        type={announcementType}
        dismissible={true}
        storageKey="site-announcement"
      />
    )
  }

  <div class="max-w-7xl mx-auto">
    <!-- 顶部工具栏（可选） -->
    {
      showSocialLinks && (
        <div class="flex justify-end py-4">
          <SocialLinks
            links={[
              {
                name: "GitHub",
                url: "https://github.com/CILXRY",
                icon: "github",
              },
              { name: "Email", url: "mailto:cilxry@outlook.com", icon: "mail" },
            ]}
            size="lg"
          />
        </div>
      )
    }

    <!-- 主内容区 -->
    <main class="pb-16 md:py-24">
      <slot />
    </main>
  </div>

  <!-- 返回顶部按钮 -->
  <BackToTop />
</BasePageFrame>
