---
// 带侧边栏导航的页面布局框架
import BasePageFrame from "./BasePageFrame.astro";
import SidebarNav from "@/layouts/LayoutComponents/SidebarNav.astro";
import BackToTop from "@/layouts/LayoutComponents/BackToTop.astro";

interface Props {
  websiteTitle?: string;
  websiteLanguage?: string;
  sidebarPosition?: "left" | "right";
}

const { 
  websiteTitle = "CILXRY 的小站",
  websiteLanguage = "zh-CN",
  sidebarPosition = "left"
} = Astro.props;

// 侧边栏导航项配置
const navItems = [
  { label: "首页", href: "/" },
  { label: "博客", href: "/blog" },
  { label: "碎碎念", href: "/echo" },
  { label: "起始页", href: "/startpage" },
  { label: "关于", href: "/about" },
];
---

<BasePageFrame {websiteTitle} {websiteLanguage}>
  <div class="flex">
    <!-- 侧边栏导航 -->
    <SidebarNav items={navItems} position={sidebarPosition} />
    
    <!-- 主内容区 -->
    <main class={`flex-1 pb-16 md:py-24 ${sidebarPosition === 'left' ? 'lg:pl-8' : 'lg:pr-8'}`}>
      <slot />
    </main>
  </div>
  
  <!-- 返回顶部按钮 -->
  <BackToTop />
</BasePageFrame>
