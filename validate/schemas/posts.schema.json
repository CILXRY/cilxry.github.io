{
  "$ref": "#/definitions/postsFrontmatter",
  "definitions": {
    "postsFrontmatter": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "default": "标题不见了呢"
        },
        "tags": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "category": {
          "type": [
            "string",
            "null"
          ]
        },
        "author": {
          "type": [
            "string",
            "null"
          ]
        },
        "draft": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "default": "描述被吃掉了啦"
        },
        "descGenAuthor": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "not": {}
                },
                {
                  "type": "string"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "descGenTime": {
          "type": "string",
          "format": "date-time"
        },
        "wordCount": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "not": {}
                },
                {
                  "type": "number"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "readingTime": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "not": {}
                },
                {
                  "type": "number"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "creation": {
          "type": "string",
          "format": "date-time",
          "default": "1970-01-01T00:00:00.000Z"
        },
        "published": {
          "type": "string",
          "format": "date-time",
          "default": "1970-01-01T00:00:00.000Z"
        },
        "warning": {
          "anyOf": [
            {
              "anyOf": [
                {
                  "not": {}
                },
                {
                  "type": "string"
                }
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "tags",
        "category",
        "author",
        "draft"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}